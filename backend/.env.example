# ── TaskApp Environment Variables ──
# Copy this file to .env and replace with your actual values

# Database
DB_URL=jdbc:mysql://localhost:3306/taskapp_db?createDatabaseIfNotExist=true
DB_USERNAME=your_username
DB_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (generate a secure Base64-encoded key for production)
JWT_SECRET=your_base64_encoded_secret_here
JWT_EXPIRATION_MS=86400000

# Cache TTLs (seconds)
CACHE_TTL_TASKS=600
CACHE_TTL_LISTS=300
